pipeline {
  agent any

  environment {
    // >>> CHANGE ONLY THESE IF NEEDED <<<
    HOST        = '54.198.173.58'           // 💡 Your new instance IP address
    REMOTE_USER = 'ubuntu'                  // 💡 SSH user for the remote server
    SSH_KEY     = '/var/lib/jenkins/.ssh/app.pem' // 💡 Private key path on Jenkins for SSH access

    // App/WAR details
    WAR_NAME    = 'hello.war' // The name of your WAR file
    APP_CTX     = 'hello'     // The context path for your application (e.g., http://HOST:8080/hello/)
  }

  stages {

    stage('Checkout & Build') {
      steps {
        sh '''
          set -eux
          echo "Workspace: $(pwd)"
          checkout scm
          ls -la
          echo "Building with Maven..."
          mvn -B -DskipTests clean package
          echo "Built artifacts:"
          ls -l target/
          test -f "target/${WAR_NAME}"
        '''
      }
    }

    stage('Deploy to Tomcat') {
      steps {
        sh '''
          set -eux
          test -f "${SSH_KEY}"
          chmod 600 "${SSH_KEY}"

          # Copy WAR to remote server
          echo "Copying ${WAR_NAME} to remote server..."
          scp -i "${SSH_KEY}" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \\
              "target/${WAR_NAME}" "${REMOTE_USER}@${HOST}:/tmp/${WAR_NAME}"

          # SSH into remote server for provisioning and deployment
          ssh -i "${SSH_KEY}" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \\
            "${REMOTE_USER}@${HOST}" '
              set -eux
              export DEBIAN_FRONTEND=noninteractive

              # Install Java and Tomcat (assuming Ubuntu/Debian and tomcat9)
              echo "Updating packages and installing Java/Tomcat9..."
              sudo apt-get update -y
              sudo apt-get install -y openjdk-11-jre-headless tomcat9 || true

              # Define Tomcat service and webapps directory
              SVC=tomcat9
              WEBAPPS=/var/lib/tomcat9/webapps
              TOMCAT_RUN_USER="tomcat" # Standard user for tomcat9 on Ubuntu/Debian
              TOMCAT_RUN_GROUP="tomcat" # Standard group for tomcat9 on Ubuntu/Debian

              # Fallback for www-data if tomcat user isn't found
              if ! id -u "$TOMCAT_RUN_USER" >/dev/null 2>&1; then
                  TOMCAT_RUN_USER="www-data"
                  TOMCAT_RUN_GROUP="www-data"
              fi
              echo "Using Tomcat service: $SVC, Webapps: $WEBAPPS, User: $TOMCAT_RUN_USER"

              # Stop Tomcat
              echo "Stopping Tomcat service..."
              sudo systemctl stop "$SVC" || true
              sleep 5

              # Clean old deployment and ensure webapps permissions
              echo "Cleaning old deployment and setting permissions for $WEBAPPS..."
              sudo rm -rf "$WEBAPPS/'"${APP_CTX}"'" "$WEBAPPS/'"${WAR_NAME}"'" || true
              sudo chown -R "$TOMCAT_RUN_USER":"$TOMCAT_RUN_GROUP" "$WEBAPPS"
              sudo chmod -R u+rwx,g+rwx,o+rx "$WEBAPPS"
              
              # Move new WAR to webapps
              echo "Moving ${WAR_NAME} to $WEBAPPS..."
              sudo mv /tmp/'"${WAR_NAME}"' "$WEBAPPS/'"${WAR_NAME}"'"
              sudo chown "$TOMCAT_RUN_USER":"$TOMCAT_RUN_GROUP" "$WEBAPPS/'"${WAR_NAME}"'"

              # Start Tomcat
              echo "Starting Tomcat service..."
              sudo systemctl start "$SVC"
              sleep 15

              # Verify deployment
              echo "Verifying WAR unpacking..."
              if [ -d "$WEBAPPS/'"${APP_CTX}"'" ]; then
                  echo "✅ WAR unpacked successfully: $WEBAPPS/'"${APP_CTX}"'"
              else
                  echo "❌ WAR not unpacked to $WEBAPPS/'"${APP_CTX}"'. Check logs for errors."
                  sudo journalctl -u "$SVC" --since "30 seconds ago" -n 50 --no-pager | grep -E "ERROR|WARN|catalina.log" || true
                  exit 1
              fi
            '
        '''
      }
    }

    stage('Smoke test') {
      steps {
        sh '''
          set -eux
          echo "Initiating smoke test for http://${HOST}:8080/${APP_CTX}/"
          for i in $(seq 1 30); do # Increased attempts for robustness
            if curl -fsS "http://${HOST}:8080/${APP_CTX}/" >/dev/null; then
              echo "App is up ✅"
              exit 0
            fi
            echo "Attempt $i: App not yet healthy. Retrying in 2 seconds..."
            sleep 2
          done
          echo "App did not become healthy in time. Final curl attempt for debugging:"
          curl -v "http://${HOST}:8080/${APP_CTX}/" || true
          exit 1
        '''
      }
    }
  }

  post {
    success { echo '✅ Deployment successful. Your application should be accessible!' }
    failure { echo '❌ Deployment failed. Review the logs from the "Deploy to Tomcat" stage.' }
  }
}
