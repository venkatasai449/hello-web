pipeline {
  agent any

  environment {
    // --- CHANGE THESE IF NEEDED ---
    HOST        = '54.198.173.58'                 // your EC2 public IP/DNS
    REMOTE_USER = 'ubuntu'                        // SSH user
    SSH_KEY     = '/var/lib/jenkins/.ssh/app.pem' // private key on Jenkins
    SERVICE     = 'tomcat9'                       // you have tomcat9
    WEBAPPS     = '/var/lib/tomcat9/webapps'      // tomcat9 webapps dir

    // App/WAR info (from your pom build)
    WAR_NAME    = 'hello.war'                     // target/hello.war
    APP_CTX     = 'hello'                         // served at /hello/
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
        sh '''
          set -eux
          echo "Workspace: $(pwd)"
          ls -la
        '''
      }
    }

    stage('Build with Maven') {
      steps {
        sh '''
          set -eux
          mvn -B -DskipTests clean package
          ls -l target/
          test -f "target/${WAR_NAME}"
        '''
      }
    }

    stage('Copy WAR to server') {
      steps {
        sh '''
          set -eux
          test -f "${SSH_KEY}"
          chmod 600 "${SSH_KEY}"
          scp -i "${SSH_KEY}" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
              "target/${WAR_NAME}" "${REMOTE_USER}@${HOST}:/tmp/${WAR_NAME}"
        '''
      }
    }

    stage('Deploy to Tomcat9') {
      steps {
        sh '''
          set -eux
          ssh -i "${SSH_KEY}" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
            "${REMOTE_USER}@${HOST}" bash -lc "
              set -eux
              sudo mkdir -p '${WEBAPPS}'
              sudo systemctl stop '${SERVICE}' || true
              sudo rm -rf '${WEBAPPS}/${APP_CTX}' '${WEBAPPS}/${WAR_NAME}' || true
              sudo mv /tmp/${WAR_NAME} '${WEBAPPS}/'
              # ownership (ignore if no tomcat user on this distro)
              (id tomcat >/dev/null 2>&1 && sudo chown tomcat:tomcat '${WEBAPPS}/${WAR_NAME}') || true
              sudo systemctl start '${SERVICE}'
              sudo systemctl is-active '${SERVICE}'
              sleep 5
            "
        '''
      }
    }

    stage('Smoke test') {
      steps {
        sh '''
          set -eux
          for i in $(seq 1 20); do
            if curl -fsS "http://${HOST}:8080/${APP_CTX}/" >/dev/null; then
              echo "✅ App is up at http://${HOST}:8080/${APP_CTX}/"
              exit 0
            fi
            sleep 2
          done
          echo "App did not become healthy in time"
          curl -v "http://${HOST}:8080/${APP_CTX}/" || true
          exit 1
        '''
      }
    }
  }

  post {
    success { echo '✅ Deployment successful.' }
    failure { echo '❌ Deployment failed. Check the Deploy/Smoke logs above.' }
  }
}
