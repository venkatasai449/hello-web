pipeline {
  agent any
  environment {
    WAR_NAME = 'hello.war'      // change if your war name is different
    PORT     = '8080'
    RUNNER   = 'jetty-runner-9.4.53.v20231009.jar'
    RUNNER_URL = "https://repo1.maven.org/maven2/org/eclipse/jetty/jetty-runner/9.4.53.v20231009/${RUNNER}"
  }
  stages {
    stage('Checkout') {
      steps {
        checkout scm
        sh 'pwd; ls -la'
      }
    }
    stage('Build WAR') {
      steps {
        sh '''
          set -eux
          mvn -B -DskipTests clean package
          ls -l target/
          test -f "target/${WAR_NAME}"
        '''
      }
    }
    stage('Fetch Jetty Runner') {
      steps {
        sh '''
          set -eux
          [ -f "${RUNNER}" ] || curl -LO "${RUNNER_URL}"
          ls -l "${RUNNER}"
        '''
      }
    }
    stage('Run WAR on 8080') {
      steps {
        sh '''
          set -eux
          # Stop any old runner using this port (best-effort)
          pkill -f "${RUNNER}.*--port ${PORT}" || true
          sleep 1

          # Start WAR at context path "/" so it’s visible at http://localhost:8080/
          nohup java -jar "${RUNNER}" --port ${PORT} --path / "target/${WAR_NAME}" \
            > jetty.log 2>&1 & echo $! > jetty.pid

          # Quick health check
          for i in $(seq 1 20); do
            if curl -fsS "http://localhost:${PORT}/" >/dev/null; then
              echo "✅ Running at: http://localhost:${PORT}/"
              exit 0
            fi
            sleep 1
          done
          echo "WAR did not become healthy"; tail -n 200 jetty.log || true; exit 1
        '''
      }
    }
  }
  post {
    success { echo '✅ Your WAR is running on http://localhost:8080/' }
    failure { echo '❌ Failed. Check jetty.log in the workspace.' }
  }
}
