pipeline {
  agent any
  options { timestamps() }
  environment {
    PORT       = '8080'
    RUNNER     = 'jetty-runner-9.4.53.v20231009.jar'
    RUNNER_URL = "https://repo1.maven.org/maven2/org/eclipse/jetty/jetty-runner/9.4.53.v20231009/${RUNNER}"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
        sh 'pwd; ls -la'
      }
    }

    stage('Build WAR') {
      steps {
        sh '''
          set -eux
          mvn -B -DskipTests clean package
          ls -l target/
          WAR_PATH="$(ls -1 target/*.war | head -n1 || true)"
          [ -n "$WAR_PATH" ] || { echo "No WAR found in target/. Did the build create it?"; exit 1; }
          echo "$WAR_PATH" > WAR_PATH.txt
        '''
      }
    }

    stage('Download Jetty Runner') {
      steps {
        sh '''
          set -eux
          command -v curl >/dev/null 2>&1 || { echo "Install curl on the Jenkins node."; exit 1; }
          [ -f "${RUNNER}" ] || curl -fL -o "${RUNNER}" "${RUNNER_URL}"
          ls -l "${RUNNER}"
        '''
      }
    }

    stage('Free port 8080') {
      steps {
        sh '''
          set -eux
          # Stop any previous Jetty Runner from this job
          pkill -f "${RUNNER}.*--port ${PORT}" || true
          sleep 1
          # Kill anything else on 8080 (best effort)
          if command -v fuser >/dev/null 2>&1; then fuser -k "${PORT}/tcp" || true; fi
          # If system Tomcat owns 8080, try to stop it (ignore if not present/allowed)
          if command -v systemctl >/dev/null 2>&1; then
            systemctl is-active --quiet tomcat9 && (sudo systemctl stop tomcat9 || true) || true
          fi
        '''
      }
    }

    stage('Run WAR on 8080') {
      steps {
        sh '''
          set -eux
          WAR_PATH="$(cat WAR_PATH.txt)"
          rm -f jetty.pid jetty.log
          nohup java -jar "${RUNNER}" --port "${PORT}" --path / "${WAR_PATH}" > jetty.log 2>&1 & echo $! > jetty.pid

          # Health check until it’s up
          for i in $(seq 1 30); do
            if curl -fsS "http://localhost:${PORT}/" >/dev/null; then
              echo "✅ Running at: http://localhost:${PORT}/"
              exit 0
            fi
            sleep 1
          done

          echo "WAR did not become healthy in time."
          tail -n 200 jetty.log || true
          exit 1
        '''
      }
    }
  }

  post {
    success { echo "✅ Your WAR is running on http://localhost:${PORT}/" }
    failure { echo "❌ Failed. Open jetty.log in the workspace for details." }
    always  {
      sh '''
        echo "--- jetty processes ---"
        ps -ef | grep jetty-runner | grep -v grep || true
        echo "--- last log lines ---"
        tail -n 50 jetty.log || true
      '''
    }
  }
}
